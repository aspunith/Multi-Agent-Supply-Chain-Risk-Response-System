# Copy to .env and fill in. Runs offline (rule-based agents) without a key;
# set USE_LLM=true to route agent reasoning through OpenAI.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
USE_LLM=false

# Business thresholds (drive the Supervisor's escalation logic)
EMERGENCY_ORDER_COST_THRESHOLD=25000
MIN_FORECAST_CONFIDENCE=0.60
